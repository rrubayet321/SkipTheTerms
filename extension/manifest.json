{
    "manifest_version": 3,
    "name": "SkipTheTerms",
    "version": "1.0.0",
    "description": "Instantly summarize Terms of Service and Privacy Policies with sarcastic bullet points.",
    "icons": {
        "16": "images/icon-16.png",
        "48": "images/icon-48.png",
        "128": "images/icon-128.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "http://localhost:8000/*",
        "<all_urls>"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "SkipTheTerms"
    }
}